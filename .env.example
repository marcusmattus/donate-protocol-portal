# Donate Protocol Environment Configuration

# Next.js
NODE_ENV=development

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Alternative: https://devnet.helius-rpc.com/?api-key=your-key

# Wallet Configuration
NEXT_PUBLIC_WALLET_ADAPTERS=phantom,solflare

# TradingView Webhook
WEBHOOK_SECRET=demo-secret-key

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id

# Jupiter Aggregator
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Database (Production)
DATABASE_URL=postgresql://user:password@localhost:5432/donate_protocol
REDIS_URL=redis://localhost:6379

# API Configuration
API_PORT=3000
API_HOST=localhost

# Feature Flags
ENABLE_REAL_TRANSACTIONS=false
ENABLE_TELEGRAM_BOT=false
ENABLE_SOLANA_DEVNET=true

# Analytics
VERCEL_ANALYTICS_ID=
